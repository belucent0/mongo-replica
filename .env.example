MONGO_ROOT_PASS="#example123!"
MONGO_PRIMARY_HOST='example-mongodb:27017'

MONGO_NAME='example'
MONGO_USER='exampleUser'
MONGO_PASS='#example123!'

# TLS (optional)
MONGO_NODE_NAME='example-mongodb'

# TLS 인증서 SAN 에 추가할 호스트 (선택)
#   기본 SAN: DNS:<MONGO_NODE_NAME>, DNS:localhost, IP:127.0.0.1
#   같은 docker-compose 안에서 컨테이너명으로 접속하는 일반적인 경우라면 비워둔다.
#   DB 를 별도 호스트에 두고 앱이 LAN IP/FQDN 으로 접속한다면 그 주소를 추가한다.
#   예) MONGO_TLS_EXTRA_SAN='IP:192.168.1.88,DNS:db.client.local'
MONGO_TLS_EXTRA_SAN=

# TLS 강제 여부
#   true  (기본/스펙 준수) → requireTLS: 앱도 TLS 필수
#                            (앱 .env 의 연결 문자열에 ?tls=true&tlsCAFile=... 필요)
#   false (호환 모드)      → allowTLS:   앱 평문/TLS 양쪽 허용 (기존 자동화 유지용)
MONGO_TLS_REQUIRED=true