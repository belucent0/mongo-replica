# 환경변수 예시 (기본 = 3노드 레플리카셋, docker-compose.yml 용)
# 실제 값은 .env 로 복사해서 사용:  cp .env.example .env
# (단일 노드 모드는 .env.single.example 참고)

COMPOSE_PROJECT_NAME=rs
MONGO_IMAGE=mongo-rs:latest
DOCKER_NETWORK_NAME=mongo-rs-net

# 데이터 노드 목록 (첫 항목이 primary 후보)
MONGO_REPLICA_HOSTS=mongo1:27017,mongo2:27017
# Arbiter (데이터 2 + Arbiter 1 구성). 데이터 3노드로 하려면 비워두고 위에 3개 나열.
MONGO_ARBITER_HOST=mongo3:27017

# 계정
MONGO_ROOT_PASS=#example123!
MONGO_NAME=example
MONGO_USER=exampleUser
MONGO_PASS=#example123!
# 백업 전용 최소권한 계정 (내장 backup 롤). 상시 도는 백업 컨테이너가 이 계정으로 mongodump.
#   root 가 아니므로 유출돼도 읽기만 가능(쓰기·삭제·서버관리 불가). 복원은 운영자가 root 로 수행.
MONGO_BACKUP_USER=backupUser
MONGO_BACKUP_PASS=#exampleBackup1!

# TLS 강제 여부
#   true  (기본/스펙 준수) → requireTLS: 앱도 TLS 필수
#                            (앱 .env 의 MONGO_DATABASE_URL 에 ?tls=true&tlsCAFile=... 필요)
#   false (호환 모드)      → preferTLS:  앱 평문/TLS 양쪽 허용
#                            (노드 간 통신은 어차피 TLS 로 암호화됨)
MONGO_TLS_REQUIRED=true

# ── 백업 (mongo-backup 서비스) ──────────────────────────────
# 호스트 백업 폴더 (bind mount). 컨테이너를 지워도 이 폴더의 백업은 보존된다.
BACKUP_DIR=./backups
# 백업 주기(초). 86400=매일, 21600=6시간, 604800=매주
BACKUP_INTERVAL=86400
# 백업 실패 시 재시도 간격(초). 기동 직후 DB 준비 전 race 나 일시적 오류를 빠르게 복구.
BACKUP_RETRY_DELAY=300
# healthcheck 신선도 여유(초). 마지막 정상 백업이 (INTERVAL + 이 값) 보다 오래되면
# 컨테이너가 unhealthy 가 된다 → `docker ps` / 모니터링이 백업 중단을 감지.
BACKUP_HEALTH_GRACE=3600
# 백업 출력 최소 크기(바이트). 이보다 작으면 비정상 dump 로 간주해 실패 처리(빈/깨진 백업 차단).
BACKUP_MIN_BYTES=500
# 보관 일수 (초과분 자동 삭제). 각 백업은 전체 덤프이므로 일수 × 하루치 ≈ 총 용량
BACKUP_RETENTION_DAYS=7
# age 공개키(recipient). 안전한 환경에서 `age-keygen -o key.txt` 로 생성한 공개키만 입력.
#   ★ 비밀키(key.txt)는 서버에 두지 말고 별도 안전한 곳(vault/오프라인)에 보관할 것.
#   ★ 비어 있으면 백업 컨테이너는 실패한다(fail-closed) — 암호화 없는 백업을 막기 위함.
#     의도적으로 평문 백업이 필요하면 BACKUP_ALLOW_PLAINTEXT=true 를 함께 설정한다(스펙 미충족).
BACKUP_AGE_RECIPIENT=
